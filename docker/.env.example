# Where the gateway listens (the app points at this).
PORT=8090

# The signal-cli-rest-api server (json-rpc mode), reachable only by the gateway.
SIGNAL_CLI_URL=http://signal-cli-rest-api:8080

# SQLite file for the message buffer, subscriptions, and per-number cursors.
DB_PATH=./data/gateway.db

# How many received frames to keep buffered per Signal number (backlog cap).
RETENTION_PER_NUMBER=500

# When true, only send a Web Push if no app WebSocket is currently connected for
# that number (the open app notifies itself). Set false to always push.
PUSH_WHEN_IDLE_ONLY=true

# Optional VAPID keys. Generate with:  npx web-push generate-vapid-keys
# When set, the app subscribes with the public key (served at /v1/push/vapid) so
# only this gateway can push. Leave blank to push without VAPID (less secure).
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:admin@example.com
