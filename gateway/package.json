{
  "name": "signal4kaios-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway in front of signal-cli-rest-api for signal4kaios: HTTP reverse proxy, receive-WebSocket relay with buffered backlog, and Web Push for closed-app notifications.",
  "license": "GPL-3.0-or-later",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "web-push": "^3.6.7",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
